# ──────────────────────────────────────────────
# XPectra — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=clinicaradiografias

# Authentication
JWT_SECRET=your_jwt_secret_here

# CORS
CORS_ORIGIN=http://localhost:3000

# Timezone offset in minutes (El Salvador = UTC-6 = -360)
TZ_OFFSET_MINUTES=-360

# Rate Limiting (requests per minute)
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_LOGIN_MAX=5

# Policies (hours)
POLICY_RESCHEDULE_MIN_HOURS=4
POLICY_CANCEL_MIN_HOURS=6

# Login cooldown (minutes of inactivity to reset lockout stage)
LOGIN_STAGE_COOLDOWN_MINUTES=120